# Super+A: open the pi-agents picker (same action as clicking the 🤖 bar indicator).
# Lists running agent-fleet agents; pick one to jump to its nvim buffer + window.
# Regolith binds $mod+a to "focus parent" by default; we disable that by parking it
# on a dead key via wm.binding.focus_parent in ~/.config/regolith3/Xresources.
bindsym $mod+a exec --no-startup-id ~/.local/bin/pi-agents-focus
