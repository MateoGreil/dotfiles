# Super+A: open the pi-agents picker (same action as clicking the 🤖 bar indicator).
# Lists running agent-fleet agents; pick one to jump to its nvim buffer + window.
# bindcode 38 (physical 'a' key), not bindsym a: the layout has two xkb groups, so
# keysym 'a' resolves twice and `bindsym $mod+a` triggers duplicate-binding errors.
bindcode $mod+38 exec --no-startup-id ~/.local/bin/pi-agents-focus
