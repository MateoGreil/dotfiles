regolith.wallpaper.file: ~/.config/backgrounds/mushishi.jpg
regolith.wallpaper.options: zoom
wm.bar.position: top
regolith.look.path: /usr/share/regolith-look/gruvbox
wm.program.terminal: /snap/bin/ghostty
! Override the look's gtk.theme_name (default "Gruvbox" is the broken
! regolith-look-gruvbox theme); use the Fausto-Korpsvart port installed by
! run_onchange_install-packages.sh.
gtk.theme_name: Gruvbox-Dark-Medium

! Free Super+A for the pi-agents picker (see i3/config.d/11_pi-agents): Regolith
! binds $mod+a to "focus parent" by default; park it on a dead key to disable it.
wm.binding.focus_parent: F13
