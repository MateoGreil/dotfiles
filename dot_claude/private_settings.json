{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.last_assistant_message' | head -c 200 | xargs -I{} notify-send 'Claude' '{}' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I{} notify-send -u normal 'Claude' '{}' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_name' | xargs -I{} notify-send -u critical 'Claude — permission needed' 'Wants to use {}' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "enableWorkflows": true,
  "statusLine": {
    "type": "command",
    "command": "/home/mat/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "product-engineering@electra-plugins": true,
    "product-engineering-experiments@electra-plugins": true,
    "product-engineering-golang@electra-plugins": true,
    "mattpocock-skills@mattpocock-wrap": true,
    "linear@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "electra-plugins": {
      "source": {
        "source": "github",
        "repo": "Go-Electra/claude-plugins"
      },
      "autoUpdate": true
    },
    "mattpocock-wrap": {
      "source": {
        "source": "directory",
        "path": "/home/mat/.local/share/claude-plugins/mattpocock-wrap"
      }
    }
  },
  "effortLevel": "xhigh",
  "ultracode": true,
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "autoCompactEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
